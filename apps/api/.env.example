# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://sher:sher_dev_password@localhost:5432/sher_dev"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=sher-dev
R2_PUBLIC_URL=http://localhost:9000/sher-dev

# ── OTP / SMS (Termii) ────────────────────────────────────────────────────────
TERMII_API_KEY=your_termii_key
TERMII_SENDER_ID=Sher
OTP_MOCK=true   # set to false in staging/prod to send real SMS

# ── Payments ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxx
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxx
FLUTTERWAVE_WEBHOOK_HASH=your_webhook_hash

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=debug
